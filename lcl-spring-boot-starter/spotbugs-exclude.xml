<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        Suppress EI_EXPOSE_REP / EI_EXPOSE_REP2 for Spring-managed beans.
        Constructor-injected dependencies are immutable singletons;
        defensive copying is not appropriate.
    -->
    <Match>
        <Or>
            <Class name="io.github.emmansun.lightcrypto.model.EncryptedFieldMetadata"/>
            <Class name="io.github.emmansun.lightcrypto.listener.EntityMetadataCache"/>
            <Class name="io.github.emmansun.lightcrypto.service.FieldCryptoService"/>
            <Class name="io.github.emmansun.lightcrypto.service.KeyVaultService"/>
            <Class name="io.github.emmansun.lightcrypto.service.ProgrammaticCryptoService"/>
            <Class name="io.github.emmansun.lightcrypto.config.ObservabilityProperties"/>
            <Class name="io.github.emmansun.lightcrypto.observability.LclMetrics"/>
            <Class name="io.github.emmansun.lightcrypto.observability.LclHealthIndicator"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
