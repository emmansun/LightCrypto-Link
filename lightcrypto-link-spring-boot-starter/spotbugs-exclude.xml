<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        Suppress EI_EXPOSE_REP / EI_EXPOSE_REP2 for Lombok @Data and Java records.
        These are false positives: the classes are internal data holders,
        and defensive copying would add unnecessary overhead.
    -->
    <Match>
        <Or>
            <Class name="io.github.emmansun.lightcrypto.model.EncryptedFieldMetadata"/>
            <Class name="io.github.emmansun.lightcrypto.model.KeyVaultDocument"/>
            <Class name="~io\.github\.emmansun\.lightcrypto\.model\.KeyVaultDocument\$.+"/>
            <Class name="io.github.emmansun.lightcrypto.model.WrappedKey"/>
            <Class name="io.github.emmansun.lightcrypto.listener.EntityMetadataCache"/>
            <Class name="io.github.emmansun.lightcrypto.query.CryptoMongoRepositoryFactory"/>
            <Class name="io.github.emmansun.lightcrypto.query.CryptoQueryLookupStrategy"/>
            <Class name="io.github.emmansun.lightcrypto.service.KeyVaultService"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
